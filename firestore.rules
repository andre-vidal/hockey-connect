rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && role in request.auth.token.roles;
    }

    function isLeagueAdmin() {
      return hasRole('league_admin');
    }

    function isMatchOfficial() {
      return hasRole('match_official');
    }

    function isClubAdmin() {
      return hasRole('club_admin');
    }

    function isTeamAdmin() {
      return hasRole('team_admin');
    }

    function isPlayer() {
      return hasRole('player');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isLeagueAdmin();
      allow delete: if isLeagueAdmin();
    }

    // App settings (league admin only for write)
    match /settings/{document} {
      allow read: if true;
      allow write: if isLeagueAdmin();
    }

    // Leagues - public read, league_admin write
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isLeagueAdmin();
      match /archivedSeasons/{seasonId} {
        allow read: if true;
        allow write: if isLeagueAdmin();
      }
    }

    // Tournaments - public read, league_admin write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isLeagueAdmin();
    }

    // Clubs - public read, league_admin write
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isLeagueAdmin();

      // Teams - club_admin or team_admin of same club can read; only club_admin can create/delete
      match /teams/{teamId} {
        allow read: if isAuthenticated();
        allow create: if isLeagueAdmin() || (isClubAdmin() && request.auth.token.clubId == clubId);
        allow update: if isLeagueAdmin() || (isClubAdmin() && request.auth.token.clubId == clubId);
        allow delete: if isLeagueAdmin() || (isClubAdmin() && request.auth.token.clubId == clubId);
      }

      // Players - club_admin can manage; team_admin can read; player can update own
      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create: if isLeagueAdmin() || (isClubAdmin() && request.auth.token.clubId == clubId);
        allow update: if isLeagueAdmin()
          || (isClubAdmin() && request.auth.token.clubId == clubId)
          || (isPlayer() && resource.data.claimedByUserId == request.auth.uid);
        allow delete: if isLeagueAdmin() || (isClubAdmin() && request.auth.token.clubId == clubId);
      }
    }

    // Match officials - authenticated read, league_admin write
    match /officials/{officialId} {
      allow read: if isAuthenticated();
      allow write: if isLeagueAdmin();
    }

    // Squads - club_admin has full club-scope access; team_admin has team-scope access
    match /squads/{squadId} {
      allow read: if isAuthenticated();
      allow create: if isLeagueAdmin()
        || (isClubAdmin() && request.auth.token.clubId == resource.data.clubId)
        || (isTeamAdmin() && request.auth.token.clubId == resource.data.clubId && resource.data.teamId in request.auth.token.teamIds);
      allow update: if isLeagueAdmin()
        || (isClubAdmin() && request.auth.token.clubId == resource.data.clubId)
        || (isTeamAdmin() && request.auth.token.clubId == resource.data.clubId && resource.data.teamId in request.auth.token.teamIds);
      allow delete: if isLeagueAdmin()
        || (isClubAdmin() && request.auth.token.clubId == resource.data.clubId)
        || (isTeamAdmin() && request.auth.token.clubId == resource.data.clubId && resource.data.teamId in request.auth.token.teamIds);
    }

    // Match rosters
    match /matchRosters/{rosterId} {
      allow read: if isAuthenticated();
      allow create: if isLeagueAdmin()
        || isMatchOfficial()
        || (isClubAdmin() && request.auth.token.clubId == resource.data.clubId)
        || (isTeamAdmin() && request.auth.token.clubId == resource.data.clubId && resource.data.teamId in request.auth.token.teamIds);
      allow update: if isLeagueAdmin()
        || (isClubAdmin() && request.auth.token.clubId == resource.data.clubId)
        || (isTeamAdmin() && request.auth.token.clubId == resource.data.clubId && resource.data.teamId in request.auth.token.teamIds);
      allow delete: if isLeagueAdmin();
    }

    // All other collections - league admin has full access
    // Fine-grained rules added per-phase
    match /{document=**} {
      allow read: if true;
      allow write: if isLeagueAdmin();
    }
  }
}
