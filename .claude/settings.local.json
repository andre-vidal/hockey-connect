{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(firebase database:set /maintenance/enabled --data \"true\" --force --project hockey-connect-decb8)",
      "Bash(firebase database:set /maintenance/enabled --data \"false\" --force --project hockey-connect-decb8)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  }
}
