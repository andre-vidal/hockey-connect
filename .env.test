# ─────────────────────────────────────────────────────────
# Hockey Connect — Playwright test environment
# Copy this file to .env.test and fill in real values.
# .env.test is git-ignored; this example file is committed.
# ─────────────────────────────────────────────────────────

# Base URL of the running Next.js app
PLAYWRIGHT_BASE_URL=http://localhost:3000

# ── Test user accounts ────────────────────────────────────
# Create these manually in Firebase Auth (Console or Admin SDK)
# before running the test suite. Set roles on each account's
# Firestore users/{uid} document, then sign in once so the
# session cookie syncs the custom claims.

# ROOT: developer-only account (access to /root dashboard)
ROOT_EMAIL=root@hockeyconnect.app
ROOT_PASSWORD=RootPassword123!

# LEAGUE_ADMIN: roles: ["league_admin"]
LEAGUE_ADMIN_EMAIL=leagueadmin@hockeyconnect.app
LEAGUE_ADMIN_PASSWORD=LeagueAdminPassword123!

# MATCH_OFFICIAL: roles: ["match_official"]
MATCH_OFFICIAL_EMAIL=official@hockeyconnect.app
MATCH_OFFICIAL_PASSWORD=OfficialPassword123!

# CLUB_ADMIN: roles: ["club_admin"]
CLUB_ADMIN_EMAIL=clubadmin@hockeyconnect.app
CLUB_ADMIN_PASSWORD=ClubAdminPassword123!
# Firestore document ID of the club this club_admin belongs to.
# Used by tests that call /api/clubs/[clubId]/teams|players etc.
CLUB_ADMIN_CLUB_ID=1q7vbgrhck1hupk7o5wbst
# Firestore document ID of a pre-seeded league used for squad creation tests.
CLUB_ADMIN_OPEN_LEAGUE_ID=jUWO0Odu4DFoWtqJ4SdN
CLUB_ADMIN_CLOSED_LEAGUE_ID=83io6IW7C08ISGFBp7m0

# TEAM_ADMIN: roles: ["team_admin"]
TEAM_ADMIN_EMAIL=teamadmin@hockeyconnect.app
TEAM_ADMIN_PASSWORD=TeamAdminPassword123!

# PLAYER: roles: ["player"]
PLAYER_EMAIL=player@hockeyconnect.app
PLAYER_PASSWORD=PlayerPassword123!

# TEST_USER: a plain authenticated account with no roles.
TEST_USER_EMAIL=test@hockeyconnect.app
TEST_USER_PASSWORD=TestPassword123!

# ── Firebase project (used by firebase-cli helper) ────────
# Must match FIREBASE_PROJECT_ID in .env.local.
FIREBASE_PROJECT_ID=hockey-connect-decb8

# ── Firebase client API key (used by auth fixture) ────────
# Same value as NEXT_PUBLIC_FIREBASE_API_KEY in .env.local.
# Needed to exchange email/password for an ID token via the
# Firebase Auth REST API, so the session cookie can be set.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDajRy84J2CAO_d9QPo4TNT4ROMEWq5yNg
